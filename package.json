{
  "name": "docuid-addin",
  "version": "0.1.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/OfficeDev/Office-Addin-TaskPane.git"
  },
  "license": "MIT",
  "config": {
    "app_to_debug": "word",
    "app_type_to_debug": "desktop",
    "dev_server_port": 3000
  },
  "scripts": {
    "build": "tsup",
    "build:dev": "tsup --minify false --sourcemap",
    "start": "tsup --watch",
    "start:dev": "tsup --watch --minify false --sourcemap",
    "start:word": "office-addin-debugging start manifest.xml --app word --dev-server \"bun run tools/dev-server-quick.ts\" --dev-server-port 3000",
    "start:excel": "office-addin-debugging start manifest-excel.xml --app excel --dev-server \"bun run tools/dev-server-quick.ts\" --dev-server-port 3000",
    "start:powerpoint": "office-addin-debugging start manifest-powerpoint.xml --app powerpoint --dev-server \"bun run tools/dev-server-quick.ts\" --dev-server-port 3000",
    "stop": "office-addin-debugging stop manifest.xml",
    "stop:word": "office-addin-debugging stop manifest.xml --app word",
    "stop:excel": "office-addin-debugging stop manifest-excel.xml --app excel",
    "stop:powerpoint": "office-addin-debugging stop manifest-powerpoint.xml --app powerpoint",
    "validate": "office-addin-manifest validate manifest.xml",
    "validate:word": "office-addin-manifest validate manifest.xml",
    "validate:excel": "office-addin-manifest validate manifest-excel.xml",
    "validate:powerpoint": "office-addin-manifest validate manifest-powerpoint.xml",
    "validate:prod": "office-addin-manifest validate manifest-production.xml",
    "start:all": "bun run tools/start-all.ts",
    "installer:build": "powershell -NoProfile -ExecutionPolicy Bypass -File ./installer/Build-Installer.ps1",
    "installer:package": "bun run validate:prod && bun run installer:build",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "signin": "office-addin-dev-settings m365-account login",
    "signout": "office-addin-dev-settings m365-account logout",
    "vercel-build": "bun run build"
  },
  "dependencies": {
    "@fluentui/react": "^8.123.0",
    "@fluentui/react-icons": "^2.0.305",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "axios": "^1.10.0",
    "core-js": "^3.36.0",
    "lucide-react": "^0.534.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-phone-number-input": "^3.4.12",
    "regenerator-runtime": "^0.14.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@esbuild-plugins/node-modules-polyfill": "^0.2.2",
    "@tailwindcss/postcss": "^4.1.11",
    "@types/office-js": "^1.0.377",
    "@types/office-runtime": "^1.0.35",
    "autoprefixer": "^10.4.21",
    "office-addin-cli": "^2.0.3",
    "office-addin-debugging": "^6.0.3",
    "office-addin-dev-certs": "^2.0.3",
    "office-addin-manifest": "^2.0.3",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.11",
    "tsup": "^8.5.1",
    "typescript": "^5.4.2"
  },
  "browserslist": [
    "last 2 versions",
    "ie 11"
  ]
}
