{
  "name": "docuid-addin",
  "version": "0.1.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/OfficeDev/Office-Addin-TaskPane.git"
  },
  "license": "MIT",
  "packageManager": "bun@1.3.14",
  "config": {
    "app_to_debug": "word",
    "app_type_to_debug": "desktop",
    "dev_server_port": 3000
  },
  "scripts": {
    "preinstall": "node -e \"if (!/bun/i.test(process.env.npm_execpath || '') && !/bun/i.test(process.env.npm_config_user_agent || '')) { console.error('\\u001b[31mError: This repository is configured to use Bun as its package manager. Running npm/pnpm/yarn install is blocked. Please use \\u0027bun install\\u0027.\\u001b[0m\\n'); process.exit(1); }\"",
    "build": "webpack --mode production",
    "build:dev": "webpack --mode development",
    "dev-server": "webpack serve --mode development",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "signin": "office-addin-dev-settings m365-account login",
    "signout": "office-addin-dev-settings m365-account logout",
    "start": "office-addin-debugging start manifests/manifest.xml",
    "start:word": "office-addin-debugging start manifests/manifest.xml --app word",
    "start:excel": "office-addin-debugging start manifests/manifest-excel.xml --app excel",
    "start:powerpoint": "office-addin-debugging start manifests/manifest-powerpoint.xml --app powerpoint",
    "stop": "office-addin-debugging stop manifests/manifest.xml",
    "stop:word": "office-addin-debugging stop manifests/manifest.xml",
    "stop:excel": "office-addin-debugging stop manifests/manifest-excel.xml",
    "stop:powerpoint": "office-addin-debugging stop manifests/manifest-powerpoint.xml",
    "dev": "office-addin-debugging start manifests/manifest-dev.xml",
    "dev:word": "office-addin-debugging start manifests/manifest-dev.xml --app word",
    "dev:excel": "office-addin-debugging start manifests/manifest-excel-dev.xml --app excel",
    "dev:powerpoint": "office-addin-debugging start manifests/manifest-powerpoint-dev.xml --app powerpoint",
    "dev:stop": "office-addin-debugging stop manifests/manifest-dev.xml",
    "dev:stop:word": "office-addin-debugging stop manifests/manifest-dev.xml",
    "dev:stop:excel": "office-addin-debugging stop manifests/manifest-excel-dev.xml",
    "dev:stop:powerpoint": "office-addin-debugging stop manifests/manifest-powerpoint-dev.xml",
    "validate": "office-addin-manifest validate manifests/manifest.xml",
    "validate:word": "office-addin-manifest validate manifests/manifest.xml",
    "validate:excel": "office-addin-manifest validate manifests/manifest-excel.xml",
    "validate:powerpoint": "office-addin-manifest validate manifests/manifest-powerpoint.xml",
    "validate:prod": "office-addin-manifest validate manifests/manifest-production.xml",
    "validate:dev": "office-addin-manifest validate manifests/manifest-dev.xml",
    "validate:dev:excel": "office-addin-manifest validate manifests/manifest-excel-dev.xml",
    "validate:dev:powerpoint": "office-addin-manifest validate manifests/manifest-powerpoint-dev.xml",
    "installer:build": "powershell -NoProfile -ExecutionPolicy Bypass -File ./installer/Build-Installer.ps1",
    "installer:package": "bun run validate:prod && bun run installer:build",
    "watch": "webpack --mode development --watch",
    "vercel-build": "bun run build"
  },
  "dependencies": {
    "@fluentui/react": "^8.123.0",
    "@fluentui/react-icons": "^2.0.305",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "axios": "^1.10.0",
    "core-js": "^3.36.0",
    "lucide-react": "^0.534.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-phone-number-input": "^3.4.12",
    "regenerator-runtime": "^0.14.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.25.4",
    "@babel/preset-react": "^7.27.1",
    "@babel/preset-typescript": "^7.23.3",
    "@biomejs/biome": "^2.4.15",
    "@tailwindcss/postcss": "^4.1.11",
    "@types/office-js": "^1.0.377",
    "@types/office-runtime": "^1.0.35",
    "autoprefixer": "^10.4.21",
    "babel-loader": "^9.1.3",
    "copy-webpack-plugin": "^12.0.2",
    "css-loader": "^7.1.2",
    "file-loader": "^6.2.0",
    "html-loader": "^5.0.0",
    "html-webpack-plugin": "^5.6.0",
    "office-addin-cli": "^2.0.3",
    "office-addin-debugging": "^6.0.3",
    "office-addin-dev-certs": "^2.0.3",
    "office-addin-manifest": "^2.0.3",
    "os-browserify": "^0.3.0",
    "postcss": "^8.5.6",
    "postcss-loader": "^8.1.1",
    "process": "^0.11.10",
    "qrcode": "^1.5.4",
    "source-map-loader": "^5.0.0",
    "style-loader": "^4.0.0",
    "tailwindcss": "^4.1.11",
    "typescript": "^5.4.2",
    "webpack": "^5.95.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "5.1.0"
  },
  "browserslist": [
    "last 2 versions",
    "ie 11"
  ]
}
