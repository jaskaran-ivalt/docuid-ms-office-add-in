# ============================================================
# DocuID Office Add-in — Environment Variables
# ============================================================
# Copy this file to .env and fill in the values.
# .env is gitignored and must never be committed.
# ============================================================

# ------------------------------------------------------------------
# BIOMETRIC_API_KEY (required)
# ------------------------------------------------------------------
# API key for the DocuID biometric authentication endpoints.
# In production: add this to Vercel → Project → Settings → Environment Variables.
# In local dev: add it here — the webpack dev proxy injects it server-side.
# Never hard-code this value in source files.
BIOMETRIC_API_KEY=your-biometric-api-key-here

# ------------------------------------------------------------------
# DEMO_PHONE and DEMO_TOKEN (optional — local dev and demo builds only)
# ------------------------------------------------------------------
# When set, entering DEMO_PHONE in the login form bypasses biometric
# auth and creates a local demo session using DEMO_TOKEN.
# Leave these unset (or empty) in production Vercel builds — webpack's
# DefinePlugin will compile them as empty strings and demo mode is disabled.
DEMO_PHONE=+919876543210
DEMO_TOKEN=demo-session-token
